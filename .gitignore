# ------------------------------------------------------------------
# Whitelist approach: ignore everything at the top level, then allow
# only the files that belong in the public repo. This keeps the venv,
# node_modules, the reused-dataset clones, and working drafts out.
# ------------------------------------------------------------------
/*
!/.gitignore
!/.gitattributes
!/README.md
!/requirements.txt
!/LICENSE
!/docs
!/smell_injection
!/eval_tool
!/arc_qwen
!/dashboard

# Within the allowed folders, still exclude generated / heavy / third-party bits:
__pycache__/
*.pyc
node_modules/
.venv/

# generated HTML reports: ignored by default (regenerate with the view_* /
# report scripts), but the four rendered visualisations are kept in the repo
# so they can be viewed without running anything.
*.html
!smell_injection/samples_report.html
!smell_injection/smell_guide.html
!eval_tool/detection_report.html
!arc_qwen/generations_report.html
!arc_qwen/evaluation_report.html

# GitHub Pages: landing page + Jekyll opt-out (serve the HTML as-is)
!/index.html
!/.nojekyll

# build/backup artifacts
*.zip
